<mvc:View                                                                                                                                                                                                                                                      
    controllerName="z.wf.zwfmanagement.controller.AdminInbox"                                                                                                                                                                                                  
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:pf="sap.suite.ui.commons"                                                                                                                                                                                                                            
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        title="Admin Inbox"                                                                                                                                                                                                                                    
        showNavButton="true"                                                                                                                                                                                                                                   
        navButtonPress=".onNavBackToDashboard"                                                                                                                                                                                                                 
    >                                                                                                                                                                                                                                                          
        <headerContent>                                                                                                                                                                                                                                        
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"                                                                                                                                                                                
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
        </headerContent>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
        <subHeader>                                                                                                                                                                                                                                            
            <Toolbar>                                                                                                                                                                                                                                          
                <ToolbarSpacer width="0" />                                                                                                                                                                                                                    
                <Breadcrumbs                                                                                                                                                                                                                                   
                    currentLocationText="{adminInboxViewModel>/currentLocation}"                                                                                                                                                                               
                    separatorStyle="BackSlash"                                                                                                                                                                                                                 
                    links="{adminInboxViewModel>/links}"                                                                                                                                                                                                       
                >                                                                                                                                                                                                                                              
                    <Link                                                                                                                                                                                                                                      
                        press=".onLinkPress"                                                                                                                                                                                                                   
                        text="{adminInboxViewModel>text}"                                                                                                                                                                                                      
                    />                                                                                                                                                                                                                                         
                </Breadcrumbs>                                                                                                                                                                                                                                 
            </Toolbar>                                                                                                                                                                                                                                         
        </subHeader>                                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                <core:Fragment                                                                                                                                                                                                                                 
                    fragmentName="z.wf.zwfmanagement.view.fragments.adminInbox.UsersTable"                                                                                                                                                                     
                    type="XML"                                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
                <core:Fragment                                                                                                                                                                                                                                 
                    fragmentName="z.wf.zwfmanagement.view.fragments.adminInbox.TasksTable"                                                                                                                                                                     
                    type="XML"                                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
                <core:Fragment                                                                                                                                                                                                                                 
                    fragmentName="z.wf.zwfmanagement.view.fragments.adminInbox.TraceLogsPanel"                                                                                                                                                                 
                    type="XML"                                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               