<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <Dialog                                                                                                                                                                                                                                                    
        id="chartFilterDialog"                                                                                                                                                                                                                                 
        title="Filter Data"                                                                                                                                                                                                                                    
        contentHeight="auto"                                                                                                                                                                                                                                   
        contentWidth="20rem"                                                                                                                                                                                                                                   
        draggable="true"                                                                                                                                                                                                                                       
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                <items>                                                                                                                                                                                                                                        
                    <Label                                                                                                                                                                                                                                     
                        text="User ID"                                                                                                                                                                                                                         
                        labelFor="chartFilterAgentInput"                                                                                                                                                                                                       
                    />                                                                                                                                                                                                                                         
                    <MultiInput                                                                                                                                                                                                                                
                        width="100%"                                                                                                                                                                                                                           
                        id="chartFilterAgentInput"                                                                                                                                                                                                             
                        showSuggestion="true"                                                                                                                                                                                                                  
                        startSuggestion="1"                                                                                                                                                                                                                    
                        showValueHelp="false"                                                                                                                                                                                                                  
                        liveChange=".onChartFilterUserLiveChange"                                                                                                                                                                                              
                        suggestionItemSelected=".onChartFilterSuggestionSelect"                                                                                                                                                                                
                        suggestionItems="{chartFilterUsers>/userIds}"                                                                                                                                                                                          
                        placeholder="{i18n>tasksMultiInputPlaceholder}"                                                                                                                                                                                        
                    >                                                                                                                                                                                                                                          
                        <suggestionItems>                                                                                                                                                                                                                      
                            <core:Item                                                                                                                                                                                                                         
                                key="{chartFilterUsers>UserId}"                                                                                                                                                                                                
                                text="{chartFilterUsers>UserId}"                                                                                                                                                                                               
                            />                                                                                                                                                                                                                                 
                        </suggestionItems>                                                                                                                                                                                                                     
                    </MultiInput>                                                                                                                                                                                                                              
                </items>                                                                                                                                                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
        <beginButton>                                                                                                                                                                                                                                          
            <Button                                                                                                                                                                                                                                            
                text="Apply"                                                                                                                                                                                                                                   
                type="Emphasized"                                                                                                                                                                                                                              
                press=".onApplyChartFilter"                                                                                                                                                                                                                    
            />                                                                                                                                                                                                                                                 
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button                                                                                                                                                                                                                                            
                text="Cancel"                                                                                                                                                                                                                                  
                press=".onCancelChartFilter"                                                                                                                                                                                                                   
            />                                                                                                                                                                                                                                                 
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               