<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:viz="sap.viz.ui5.controls"                                                                                                                                                                                                                           
    xmlns:vizData="sap.viz.ui5.data"                                                                                                                                                                                                                           
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"                                                                                                                                                                                                         
>                                                                                                                                                                                                                                                              
    <Panel                                                                                                                                                                                                                                                     
        class="sapUiSmallMargin productivityPanel"                                                                                                                                                                                                             
        width="98.5%"                                                                                                                                                                                                                                          
    >                                                                                                                                                                                                                                                          
        <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                        
            <Toolbar style="Clear">                                                                                                                                                                                                                            
                <ToolbarSpacer />                                                                                                                                                                                                                              
                <Title text="{i18n>productivityTrendHeader}" level="H4" />                                                                                                                                                                                     
                <ToolbarSpacer />                                                                                                                                                                                                                              
                <Button icon="sap-icon://message-information" type="Transparent" press=".onChartInfoPress">                                                                                                                                                    
                    <customData>                                                                                                                                                                                                                               
                        <core:CustomData key="chartType" value="productivity" />                                                                                                                                                                               
                    </customData>                                                                                                                                                                                                                              
                </Button>                                                                                                                                                                                                                                      
            </Toolbar>                                                                                                                                                                                                                                         
            <viz:VizFrame                                                                                                                                                                                                                                      
                id="productivityVizFrame"                                                                                                                                                                                                                      
                vizType="timeseries_line"                                                                                                                                                                                                                      
                width="100%"                                                                                                                                                                                                                                   
                height="380px"                                                                                                                                                                                                                                 
                busy="{productivityModel>/loading}"                                                                                                                                                                                                            
            >                                                                                                                                                                                                                                                  
                <viz:dataset>                                                                                                                                                                                                                                  
                    <vizData:FlattenedDataset data="{productivityModel>/data}">                                                                                                                                                                                
                        <vizData:dimensions>                                                                                                                                                                                                                   
                            <vizData:DimensionDefinition                                                                                                                                                                                                       
                                name="Completion Date"                                                                                                                                                                                                         
                                value="{CompletionDate}"                                                                                                                                                                                                       
                                dataType="date"                                                                                                                                                                                                                
                            />                                                                                                                                                                                                                                 
                        </vizData:dimensions>                                                                                                                                                                                                                  
                        <vizData:measures>                                                                                                                                                                                                                     
                            <vizData:MeasureDefinition                                                                                                                                                                                                         
                                name="Completed Tasks"                                                                                                                                                                                                         
                                value="{CompletedCount}"                                                                                                                                                                                                       
                            />                                                                                                                                                                                                                                 
                            <vizData:MeasureDefinition                                                                                                                                                                                                         
                                name="Avg Processing Time"                                                                                                                                                                                                     
                                value="{AvgProcessingTime}"                                                                                                                                                                                                    
                            />                                                                                                                                                                                                                                 
                        </vizData:measures>                                                                                                                                                                                                                    
                    </vizData:FlattenedDataset>                                                                                                                                                                                                                
                </viz:dataset>                                                                                                                                                                                                                                 
                <viz:feeds>                                                                                                                                                                                                                                    
                    <vizFeeds:FeedItem                                                                                                                                                                                                                         
                        uid="timeAxis"                                                                                                                                                                                                                         
                        type="Dimension"                                                                                                                                                                                                                       
                        values="Completion Date"                                                                                                                                                                                                               
                    />                                                                                                                                                                                                                                         
                    <vizFeeds:FeedItem                                                                                                                                                                                                                         
                        uid="valueAxis"                                                                                                                                                                                                                        
                        type="Measure"                                                                                                                                                                                                                         
                        values="Completed Tasks"                                                                                                                                                                                                               
                    />                                                                                                                                                                                                                                         
                    <vizFeeds:FeedItem                                                                                                                                                                                                                         
                        uid="valueAxis2"                                                                                                                                                                                                                       
                        type="Measure"                                                                                                                                                                                                                         
                        values="Avg Processing Time"                                                                                                                                                                                                           
                    />                                                                                                                                                                                                                                         
                </viz:feeds>                                                                                                                                                                                                                                   
            </viz:VizFrame>                                                                                                                                                                                                                                    
        </VBox>                                                                                                                                                                                                                                                
    </Panel>                                                                                                                                                                                                                                                   
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               