<mvc:View                                                                                                                                                                                                                                                      
    controllerName="z.wf.zwfmanagement.controller.UserKPIDashboard"                                                                                                                                                                                            
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    displayBlock="true"                                                                                                                                                                                                                                        
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        title="{i18n>userKPIDashboardTitle}"                                                                                                                                                                                                                   
        showNavButton="true"                                                                                                                                                                                                                                   
        navButtonPress=".onNavBackToDashboard"                                                                                                                                                                                                                 
    >                                                                                                                                                                                                                                                          
        <headerContent>                                                                                                                                                                                                                                        
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"                                                                                                                                                                                
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
        </headerContent>                                                                                                                                                                                                                                       
        <content>                                                                                                                                                                                                                                              
            <!-- Section 1: Task KPIs -->                                                                                                                                                                                                                      
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.userKPIDashboard.TaskKPIs"                                                                                                                                                                     
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            <!-- Section 2: Performance Overview -->                                                                                                                                                                                                           
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.userKPIDashboard.PerformanceOverview"                                                                                                                                                          
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            <!-- Section 3: Productivity Trend -->                                                                                                                                                                                                             
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.userKPIDashboard.ProductivityTrend"                                                                                                                                                            
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            <!-- Section 4: Workflow Workload Distribution -->                                                                                                                                                                                                 
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.userKPIDashboard.WorkloadDistribution"                                                                                                                                                         
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               