<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <SelectDialog                                                                                                                                                                                                                                              
        id="valueHelpDialog"                                                                                                                                                                                                                                   
        title="{i18n>WorklistFilterTasksAll}"                                                                                                                                                                                                                  
        items="{                                                                                                                                                                                                                                               
            path: '/WfTasks',                                                                                                                                                                                                                                  
            sorter: {                                                                                                                                                                                                                                          
                path: 'Priority',                                                                                                                                                                                                                              
                descending: false                                                                                                                                                                                                                              
            },                                                                                                                                                                                                                                                 
            filters: [{                                                                                                                                                                                                                                        
                path: 'TechnicalStatus',                                                                                                                                                                                                                       
                operator: 'EQ',                                                                                                                                                                                                                                
                value1: 'SELECTED'                                                                                                                                                                                                                             
            }]                                                                                                                                                                                                                                                 
        }"                                                                                                                                                                                                                                                     
        search="_handleValueHelpSearch"                                                                                                                                                                                                                        
        confirm="onCloseTaskSearchHelp"                                                                                                                                                                                                                        
        cancel="onCloseTaskSearchHelp"                                                                                                                                                                                                                         
        multiSelect="true"                                                                                                                                                                                                                                     
    >                                                                                                                                                                                                                                                          
        <CustomListItem>                                                                                                                                                                                                                                       
            <HBox                                                                                                                                                                                                                                              
                justifyContent="SpaceBetween"                                                                                                                                                                                                                  
                alignItems="Center"                                                                                                                                                                                                                            
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <VBox>                                                                                                                                                                                                                                         
                    <Title                                                                                                                                                                                                                                     
                        text="{WorkItemText}"                                                                                                                                                                                                                  
                        level="H3"                                                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                    <Text text="{WorkItemID}" />                                                                                                                                                                                                               
                    <ObjectStatus&nbsp;                                                                                                                                                                                                                        
                        text="{TechnicalStatus}"                                                                                                                                                                                                               
                        state="{                                                                                                                                                                                                                               
                            path: 'TechnicalStatus',                                                                                                                                                                                                           
                            formatter: '.formatter.formatTechnicalStatus'                                                                                                                                                                                      
                        }"                                                                                                                                                                                                                                     
                        class="sapUiTinyMarginTop sapUiTextBold"                                                                                                                                                                                               
                    />                                                                                                                                                                                                                                         
                </VBox>                                                                                                                                                                                                                                        
                <ObjectStatus                                                                                                                                                                                                                                  
                    text="{PriorityText}"                                                                                                                                                                                                                      
                    state="{                                                                                                                                                                                                                                   
                        path: 'Priority',                                                                                                                                                                                                                      
                        formatter: '.formatter.formatPriorityState'                                                                                                                                                                                            
                    }"                                                                                                                                                                                                                                         
                    icon="{                                                                                                                                                                                                                                    
                        path: 'Priority',                                                                                                                                                                                                                      
                        formatter: '.formatter.formatPriorityIcon'                                                                                                                                                                                             
                    }"                                                                                                                                                                                                                                         
                />                                                                                                                                                                                                                                             
            </HBox>                                                                                                                                                                                                                                            
        </CustomListItem>                                                                                                                                                                                                                                      
    </SelectDialog>                                                                                                                                                                                                                                            
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               