<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <SelectDialog                                                                                                                                                                                                                                              
        id="valueHelpDialog"                                                                                                                                                                                                                                   
        title="{i18n>WorklistFilterTasksAll}"                                                                                                                                                                                                                  
        items="{                                                                                                                                                                                                                                               
            path: '/WfTasks',                                                                                                                                                                                                                                  
            sorter: {                                                                                                                                                                                                                                          
                path: 'Priority',                                                                                                                                                                                                                              
                descending: false                                                                                                                                                                                                                              
            }&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                  
        }"                                                                                                                                                                                                                                                     
        search="_handleValueHelpSearch"                                                                                                                                                                                                                        
        confirm="onCloseTaskSearchHelp"                                                                                                                                                                                                                        
        cancel="onCloseTaskSearchHelp"                                                                                                                                                                                                                         
        multiSelect="true"                                                                                                                                                                                                                                     
    >                                                                                                                                                                                                                                                          
        <CustomListItem>                                                                                                                                                                                                                                       
            <HBox                                                                                                                                                                                                                                              
                justifyContent="SpaceBetween"                                                                                                                                                                                                                  
                alignItems="Center"                                                                                                                                                                                                                            
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <VBox>                                                                                                                                                                                                                                         
                    <Title                                                                                                                                                                                                                                     
                        text="{WorkItemText}"                                                                                                                                                                                                                  
                        level="H3"                                                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                    <Text text="{WorkItemID}" />                                                                                                                                                                                                               
                </VBox>                                                                                                                                                                                                                                        
                <Text text="{PriorityText}" />                                                                                                                                                                                                                 
            </HBox>                                                                                                                                                                                                                                            
        </CustomListItem>                                                                                                                                                                                                                                      
    </SelectDialog>                                                                                                                                                                                                                                            
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               