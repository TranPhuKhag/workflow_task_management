<mvc:View                                                                                                                                                                                                                                                      
    controllerName="z.wf.zwfmanagement.controller.MainView"                                                                                                                                                                                                    
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:l="sap.ui.layout"                                                                                                                                                                                                                                    
    xmlns:f="sap.f"                                                                                                                                                                                                                                            
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <f:DynamicPage                                                                                                                                                                                                                                             
        id="dynamicPage"                                                                                                                                                                                                                                       
        headerExpanded="true"                                                                                                                                                                                                                                  
        showFooter="{= !${worklistView>/detailVisible} }"                                                                                                                                                                                                      
        toggleHeaderOnTitleClick="false"                                                                                                                                                                                                                       
    >                                                                                                                                                                                                                                                          
        <f:title>                                                                                                                                                                                                                                              
            <f:DynamicPageTitle>                                                                                                                                                                                                                               
                <f:heading>                                                                                                                                                                                                                                    
                    <HBox alignItems="Center">                                                                                                                                                                                                                 
                        <Button                                                                                                                                                                                                                                
                            type="Back"                                                                                                                                                                                                                        
                            press=".onNavBackToDashboard"                                                                                                                                                                                                      
                            class="sapUiSmallMarginEnd"                                                                                                                                                                                                        
                        />                                                                                                                                                                                                                                     
                        <Title text="{i18n>title}" />                                                                                                                                                                                                          
                    </HBox>                                                                                                                                                                                                                                    
                </f:heading>                                                                                                                                                                                                                                   
                <f:actions>                                                                                                                                                                                                                                    
                    <core:Fragment                                                                                                                                                                                                                             
                        fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"                                                                                                                                                                        
                        type="XML"                                                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                </f:actions>                                                                                                                                                                                                                                   
            </f:DynamicPageTitle>                                                                                                                                                                                                                              
        </f:title>                                                                                                                                                                                                                                             
        <f:content>                                                                                                                                                                                                                                            
            <IconTabBar                                                                                                                                                                                                                                        
                id="iconTabBar"                                                                                                                                                                                                                                
                select=".onFilterStatus"                                                                                                                                                                                                                       
                expandable="false"                                                                                                                                                                                                                             
                stretchContentHeight="true"                                                                                                                                                                                                                    
                upperCase="true"                                                                                                                                                                                                                               
                headerMode="Standard"                                                                                                                                                                                                                          
            >                                                                                                                                                                                                                                                  
                <items>                                                                                                                                                                                                                                        
                    <core:Fragment                                                                                                                                                                                                                             
                        fragmentName="z.wf.zwfmanagement.view.fragments.main.StatusTabFilter"                                                                                                                                                                  
                        type="XML"                                                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                </items>                                                                                                                                                                                                                                       
                <content>                                                                                                                                                                                                                                      
                    <ScrollContainer                                                                                                                                                                                                                           
                        height="100%"                                                                                                                                                                                                                          
                        width="100%"                                                                                                                                                                                                                           
                        vertical="true"                                                                                                                                                                                                                        
                        horizontal="false"                                                                                                                                                                                                                     
                    >                                                                                                                                                                                                                                          
                        <core:Fragment                                                                                                                                                                                                                         
                            fragmentName="z.wf.zwfmanagement.view.fragments.main.TaskTable"                                                                                                                                                                    
                            type="XML"                                                                                                                                                                                                                         
                        />                                                                                                                                                                                                                                     
                    </ScrollContainer>                                                                                                                                                                                                                         
                </content>                                                                                                                                                                                                                                     
            </IconTabBar>                                                                                                                                                                                                                                      
        </f:content>                                                                                                                                                                                                                                           
        <f:footer>                                                                                                                                                                                                                                             
            <OverflowToolbar class="sapUiTinyMarginBottom">                                                                                                                                                                                                    
                <ToolbarSpacer />                                                                                                                                                                                                                              
                <Button                                                                                                                                                                                                                                        
                    type="Ghost"                                                                                                                                                                                                                               
                    text="{i18n>buttonFooterDelegate}"                                                                                                                                                                                                         
                    press=".onBulkDelegatePress"                                                                                                                                                                                                               
                />                                                                                                                                                                                                                                             
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </f:footer>                                                                                                                                                                                                                                            
    </f:DynamicPage>                                                                                                                                                                                                                                           
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               