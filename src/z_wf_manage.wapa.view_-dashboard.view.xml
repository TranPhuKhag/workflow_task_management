<mvc:View                                                                                                                                                                                                                                                      
    controllerName="z.wf.zwfmanagement.controller.Dashboard"                                                                                                                                                                                                   
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    displayBlock="true"                                                                                                                                                                                                                                        
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:microchart="sap.suite.ui.microchart"                                                                                                                                                                                                                 
>                                                                                                                                                                                                                                                              
    <Page title="{i18n>dashboardTitle}">                                                                                                                                                                                                                       
        <headerContent>                                                                                                                                                                                                                                        
            <core:Fragment                                                                                                                                                                                                                                     
                fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"                                                                                                                                                                                
                type="XML"                                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
        </headerContent>                                                                                                                                                                                                                                       
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiMediumMargin">                                                                                                                                                                                                                   
                <Title text="{i18n>dashboardMenu}" />                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                <HBox                                                                                                                                                                                                                                          
                    wrap="Wrap"                                                                                                                                                                                                                                
                    renderType="Bare"                                                                                                                                                                                                                          
                    class="sapUiTinyMarginTop"                                                                                                                                                                                                                 
                >                                                                                                                                                                                                                                              
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardTaskManagement}"                                                                                                                                                                                                
                        subheader="{i18n>dashboardTaskSubheader}"                                                                                                                                                                                              
                        press=".onNavToTask"                                                                                                                                                                                                                   
                        state="{= ${path: '/WfTasks/$count', targetType: 'any'} === undefined ? 'Loading' : 'Loaded'}"                                                                                                                                         
                    >                                                                                                                                                                                                                                          
                        <TileContent unit="{i18n>tasksUnit}">                                                                                                                                                                                                  
                            <NumericContent                                                                                                                                                                                                                    
                                value="{                                                                                                                                                                                                                       
                                    path: '/WfTasks/$count',                                                                                                                                                                                                   
                                    parameters: {                                                                                                                                                                                                              
                                        $filter: 'TechnicalStatus eq \'READY\' or TechnicalStatus eq \'SELECTED\''                                                                                                                                             
                                    }                                                                                                                                                                                                                          
                                }"                                                                                                                                                                                                                             
                                icon="sap-icon://activities"                                                                                                                                                                                                   
                                withMargin="false"                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardSubstitution}"                                                                                                                                                                                                  
                        subheader="{i18n>dashboardSubstitutionSubheader}"                                                                                                                                                                                      
                        press=".onNavToSubstitution"                                                                                                                                                                                                           
                    >                                                                                                                                                                                                                                          
                        <TileContent>                                                                                                                                                                                                                          
                            <ImageContent src="sap-icon://collaborate" />                                                                                                                                                                                      
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardMyKPIs}"                                                                                                                                                                                                        
                        subheader="{i18n>dashboardMyKPIsSubheader}"                                                                                                                                                                                            
                        press=".onNavToUserKPIDashboard"                                                                                                                                                                                                       
                    >                                                                                                                                                                                                                                          
                        <TileContent>                                                                                                                                                                                                                          
                            <ImageContent                                                                                                                                                                                                                      
                                src="sap-icon://kpi-managing-my-area"                                                                                                                                                                                          
                            />                                                                                                                                                                                                                                 
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                </HBox>                                                                                                                                                                                                                                        
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox                                                                                                                                                                                                                                              
                class="sapUiMediumMargin"                                                                                                                                                                                                                      
                visible="{userRole>/isAdmin}"                                                                                                                                                                                                                  
            >                                                                                                                                                                                                                                                  
                <Title text="{i18n>dashboardAdminMenu}" />                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                <HBox                                                                                                                                                                                                                                          
                    wrap="Wrap"                                                                                                                                                                                                                                
                    renderType="Bare"                                                                                                                                                                                                                          
                    class="sapUiTinyMarginTop"                                                                                                                                                                                                                 
                >                                                                                                                                                                                                                                              
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardRoleManagement}"                                                                                                                                                                                                
                        subheader="{i18n>dashboardRoleManagementSubheader}"                                                                                                                                                                                    
                        press=".onNavToRoleManagement"                                                                                                                                                                                                         
                    >                                                                                                                                                                                                                                          
                        <TileContent>                                                                                                                                                                                                                          
                            <ImageContent src="sap-icon://manager" />                                                                                                                                                                                          
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardReports}"                                                                                                                                                                                                       
                        subheader="{i18n>dashboardReportsSubheader}"                                                                                                                                                                                           
                        press=".onNavToAnalytics"                                                                                                                                                                                                              
                        visible="{userRole>/isAdmin}"                                                                                                                                                                                                          
                    >                                                                                                                                                                                                                                          
                        <TileContent>                                                                                                                                                                                                                          
                            <ImageContent src="sap-icon://bar-chart" />                                                                                                                                                                                        
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <GenericTile                                                                                                                                                                                                                               
                        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"                                                                                                                                                                                     
                        header="{i18n>dashboardAdminInbox}"                                                                                                                                                                                                    
                        subheader="{i18n>dashboardAdminInboxSubheader}"                                                                                                                                                                                        
                        press=".onNavToAdminInbox"                                                                                                                                                                                                             
                        frameType="TwoByOne"                                                                                                                                                                                                                   
                        state="{= ${path: 'adminInbox>/AdminInbox/$count', targetType: 'any'} === undefined ? 'Loading' : 'Loaded'}"                                                                                                                           
                    >                                                                                                                                                                                                                                          
                        <TileContent unit="{i18n>tasksUnit}">                                                                                                                                                                                                  
                            <NumericContent                                                                                                                                                                                                                    
                                value="{                                                                                                                                                                                                                       
                                    path:'adminInbox>/AdminInbox/$count',                                                                                                                                                                                      
                                    type:'sap.ui.model.type.Integer',                                                                                                                                                                                          
                                    parameters: {                                                                                                                                                                                                              
                                        $filter: 'TechnicalStatus eq \'SELECTED\' or TechnicalStatus eq \'WAITING\''                                                                                                                                           
                                    }                                                                                                                                                                                                                          
                                }"                                                                                                                                                                                                                             
                                icon="sap-icon://inbox"                                                                                                                                                                                                        
                                valueColor="Neutral"                                                                                                                                                                                                           
                                indicator="None"                                                                                                                                                                                                               
                                withMargin="false"                                                                                                                                                                                                             
                                animateTextChange="true"                                                                                                                                                                                                       
                            />                                                                                                                                                                                                                                 
                        </TileContent>                                                                                                                                                                                                                         
                        <TileContent>                                                                                                                                                                                                                          
                            <microchart:ComparisonMicroChart                                                                                                                                                                                                   
                                view="Normal"                                                                                                                                                                                                                  
                                size="Responsive"                                                                                                                                                                                                              
                                height="100%"                                                                                                                                                                                                                  
                            >                                                                                                                                                                                                                                  
                                <microchart:data>                                                                                                                                                                                                              
                                    <microchart:ComparisonMicroChartData                                                                                                                                                                                       
                                        title="{i18n>dashboardAdminInboxClaimedStatus}"                                                                                                                                                                        
                                        value="{                                                                                                                                                                                                               
                                            path:'adminInbox>/AdminInbox/$count',                                                                                                                                                                              
                                            type:'sap.ui.model.type.Integer',                                                                                                                                                                                  
                                            parameters: {                                                                                                                                                                                                      
                                                $filter: 'TechnicalStatus eq \'SELECTED\''                                                                                                                                                                     
                                            }                                                                                                                                                                                                                  
                                        }"                                                                                                                                                                                                                     
                                        color="Good"                                                                                                                                                                                                           
                                        class="sapUiSmallMarginBottom"                                                                                                                                                                                         
                                    />                                                                                                                                                                                                                         
                                    <microchart:ComparisonMicroChartData                                                                                                                                                                                       
                                        title="{i18n>dashboardAdminInboxWaitingStatus}"                                                                                                                                                                        
                                        value="{                                                                                                                                                                                                               
                                            path:'adminInbox>/AdminInbox/$count',                                                                                                                                                                              
                                            type:'sap.ui.model.type.Integer',                                                                                                                                                                                  
                                            parameters: {                                                                                                                                                                                                      
                                                $filter: 'TechnicalStatus eq \'WAITING\''                                                                                                                                                                      
                                            }                                                                                                                                                                                                                  
                                        }"                                                                                                                                                                                                                     
                                        color="Critical"                                                                                                                                                                                                       
                                    />                                                                                                                                                                                                                         
                                </microchart:data>                                                                                                                                                                                                             
                            </microchart:ComparisonMicroChart>                                                                                                                                                                                                 
                        </TileContent>                                                                                                                                                                                                                         
                    </GenericTile>                                                                                                                                                                                                                             
                </HBox>                                                                                                                                                                                                                                        
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               