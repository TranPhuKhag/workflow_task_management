<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns="sap.suite.ui.commons.networkgraph"                                                                                                                                                                                                                  
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:m="sap.m"                                                                                                                                                                                                                                            
>                                                                                                                                                                                                                                                              
    <Graph                                                                                                                                                                                                                                                     
        enableWheelZoom="false"                                                                                                                                                                                                                                
        id="graph"                                                                                                                                                                                                                                             
        orientation="TopBottom"                                                                                                                                                                                                                                
        height="100%"                                                                                                                                                                                                                                          
        width="100%"                                                                                                                                                                                                                                           
        nodes="{traceLogGraph>/nodes}"                                                                                                                                                                                                                         
        lines="{traceLogGraph>/lines}"                                                                                                                                                                                                                         
    >                                                                                                                                                                                                                                                          
        <nodes>                                                                                                                                                                                                                                                
            <Node                                                                                                                                                                                                                                              
                key="{traceLogGraph>key}"                                                                                                                                                                                                                      
                title="{traceLogGraph>title}"                                                                                                                                                                                                                  
                icon="{traceLogGraph>icon}"                                                                                                                                                                                                                    
                status="{traceLogGraph>status}"                                                                                                                                                                                                                
                shape="Box"                                                                                                                                                                                                                                    
            >                                                                                                                                                                                                                                                  
                <attributes>                                                                                                                                                                                                                                   
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeParentWorkItemID}"                                                                                                                                                                                      
                        value="{traceLogGraph>parentWorkItemID}"                                                                                                                                                                                               
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeStepWorkItemID}"                                                                                                                                                                                        
                        value="{traceLogGraph>stepWorkItemID}"                                                                                                                                                                                                 
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeTaskID}"                                                                                                                                                                                                
                        value="{traceLogGraph>taskID}"                                                                                                                                                                                                         
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeTaskShortText}"                                                                                                                                                                                         
                        value="{traceLogGraph>taskShortText}"                                                                                                                                                                                                  
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeWorkItemType}"                                                                                                                                                                                          
                        value="{traceLogGraph>workItemType}"                                                                                                                                                                                                   
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributePriority}"                                                                                                                                                                                              
                        value="{traceLogGraph>priority}"                                                                                                                                                                                                       
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeNodeID}"                                                                                                                                                                                                
                        value="{traceLogGraph>nodeID}"                                                                                                                                                                                                         
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributePredecessor}"                                                                                                                                                                                           
                        value="{traceLogGraph>predecessorWI}"                                                                                                                                                                                                  
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeParentWorkItem}"                                                                                                                                                                                        
                        value="{traceLogGraph>parentWorkItem}"                                                                                                                                                                                                 
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeCompleted}"                                                                                                                                                                                             
                        value="{traceLogGraph>completedDate} {traceLogGraph>completedTime}"                                                                                                                                                                    
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeReturnCode}"                                                                                                                                                                                            
                        value="{traceLogGraph>returnCode}"                                                                                                                                                                                                     
                    />                                                                                                                                                                                                                                         
                    <ElementAttribute                                                                                                                                                                                                                          
                        label="{i18n>traceLogsAttributeDeadlineStatus}"                                                                                                                                                                                        
                        value="{traceLogGraph>deadlineStatus}"                                                                                                                                                                                                 
                    />                                                                                                                                                                                                                                         
                </attributes>                                                                                                                                                                                                                                  
                <content>                                                                                                                                                                                                                                      
                    <m:VBox                                                                                                                                                                                                                                    
                        class="sapUiSmallMargin"                                                                                                                                                                                                               
                        gap="0.5rem"                                                                                                                                                                                                                           
                    >                                                                                                                                                                                                                                          
                        <m:HBox                                                                                                                                                                                                                                
                            alignItems="Center"                                                                                                                                                                                                                
                            justifyContent="SpaceBetween"                                                                                                                                                                                                      
                        >                                                                                                                                                                                                                                      
                            <m:Label                                                                                                                                                                                                                           
                                text="{i18n>traceLogsContentStatus}"                                                                                                                                                                                           
                                labelFor="statusText"                                                                                                                                                                                                          
                            />                                                                                                                                                                                                                                 
                            <m:Text                                                                                                                                                                                                                            
                                id="statusText"                                                                                                                                                                                                                
                                text="{traceLogGraph>stepStatus}"                                                                                                                                                                                              
                            />                                                                                                                                                                                                                                 
                        </m:HBox>                                                                                                                                                                                                                              
                        <m:HBox                                                                                                                                                                                                                                
                            alignItems="Center"                                                                                                                                                                                                                
                            justifyContent="SpaceBetween"                                                                                                                                                                                                      
                        >                                                                                                                                                                                                                                      
                            <m:Label                                                                                                                                                                                                                           
                                text="{i18n>traceLogsContentAgent}"                                                                                                                                                                                            
                                labelFor="agentText"                                                                                                                                                                                                           
                            />                                                                                                                                                                                                                                 
                            <m:Text                                                                                                                                                                                                                            
                                id="agentText"                                                                                                                                                                                                                 
                                text="{traceLogGraph>agent}"                                                                                                                                                                                                   
                            />                                                                                                                                                                                                                                 
                        </m:HBox>                                                                                                                                                                                                                              
                        <m:HBox                                                                                                                                                                                                                                
                            alignItems="Center"                                                                                                                                                                                                                
                            justifyContent="SpaceBetween"                                                                                                                                                                                                      
                        >                                                                                                                                                                                                                                      
                            <m:Label                                                                                                                                                                                                                           
                                text="{i18n>traceLogsContentCreated}"                                                                                                                                                                                          
                                labelFor="createdText"                                                                                                                                                                                                         
                            />                                                                                                                                                                                                                                 
                            <m:Text                                                                                                                                                                                                                            
                                id="createdText"                                                                                                                                                                                                               
                                text="{traceLogGraph>stepCreationDate} {traceLogGraph>stepCreationTime}"                                                                                                                                                       
                            />                                                                                                                                                                                                                                 
                        </m:HBox>                                                                                                                                                                                                                              
                        <m:HBox                                                                                                                                                                                                                                
                            alignItems="Center"                                                                                                                                                                                                                
                            justifyContent="SpaceBetween"                                                                                                                                                                                                      
                        >                                                                                                                                                                                                                                      
                            <m:Label                                                                                                                                                                                                                           
                                text="{i18n>traceLogsContentLog}"                                                                                                                                                                                              
                                labelFor="logText"                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                            <m:Text                                                                                                                                                                                                                            
                                id="logText"                                                                                                                                                                                                                   
                                text="{traceLogGraph>logDate} {traceLogGraph>logTime}"                                                                                                                                                                         
                            />                                                                                                                                                                                                                                 
                        </m:HBox>                                                                                                                                                                                                                              
                    </m:VBox>                                                                                                                                                                                                                                  
                </content>                                                                                                                                                                                                                                     
            </Node>                                                                                                                                                                                                                                            
        </nodes>                                                                                                                                                                                                                                               
        <lines>                                                                                                                                                                                                                                                
            <Line                                                                                                                                                                                                                                              
                from="{traceLogGraph>from}"                                                                                                                                                                                                                    
                to="{traceLogGraph>to}"                                                                                                                                                                                                                        
            />                                                                                                                                                                                                                                                 
        </lines>                                                                                                                                                                                                                                               
    </Graph>                                                                                                                                                                                                                                                   
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               