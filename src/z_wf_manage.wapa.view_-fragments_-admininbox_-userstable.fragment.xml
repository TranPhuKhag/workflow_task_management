<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <Table                                                                                                                                                                                                                                                     
        id="adminInboxUsersTable"                                                                                                                                                                                                                              
        busy="{adminInboxViewModel>/isUsersBusy}"                                                                                                                                                                                                              
        visible="{adminInboxViewModel>/isUsersVisible}"                                                                                                                                                                                                        
        items="{                                                                                                                                                                                                                                               
            path: 'adminInboxViewModel>/users',                                                                                                                                                                                                                
            sorter: {                                                                                                                                                                                                                                          
                path: 'UserID',&nbsp;                                                                                                                                                                                                                          
                descending: false&nbsp;                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
        }"                                                                                                                                                                                                                                                     
        itemPress=".onUserPress"                                                                                                                                                                                                                               
        sticky="ColumnHeaders,HeaderToolbar"                                                                                                                                                                                                                   
    >                                                                                                                                                                                                                                                          
        <headerToolbar>                                                                                                                                                                                                                                        
            <OverflowToolbar width="100%">                                                                                                                                                                                                                     
                <Title                                                                                                                                                                                                                                         
                    busy="{adminInboxViewModel>/isUsersBusy}"                                                                                                                                                                                                  
                    text="{i18n>userTitle} ({adminInboxViewModel>/countTotal})"                                                                                                                                                                                
                    level="H2"                                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
                <ToolbarSpacer />                                                                                                                                                                                                                              
                <SearchField                                                                                                                                                                                                                                   
                    width="auto"                                                                                                                                                                                                                               
                    search=".onSearchUsers"                                                                                                                                                                                                                    
                    placeholder="{i18n>userInputPlaceholder}"                                                                                                                                                                                                  
                    tooltip="{i18n>tooltipHeaderSearch}"                                                                                                                                                                                                       
                />                                                                                                                                                                                                                                             
                <Button                                                                                                                                                                                                                                        
                    icon="sap-icon://sort"                                                                                                                                                                                                                     
                    press=".onSortUsers"                                                                                                                                                                                                                       
                    tooltip="{i18n>tooltipHeaderSort}"                                                                                                                                                                                                         
                />                                                                                                                                                                                                                                             
                <Button                                                                                                                                                                                                                                        
                    icon="sap-icon://filter"                                                                                                                                                                                                                   
                    press=".onFilterUsers"                                                                                                                                                                                                                     
                    tooltip="{i18n>tooltipHeaderFilter}"                                                                                                                                                                                                       
                />                                                                                                                                                                                                                                             
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </headerToolbar>                                                                                                                                                                                                                                       
        <columns>                                                                                                                                                                                                                                              
            <Column>                                                                                                                                                                                                                                           
                <Text text="{i18n>userUniqueName}" />                                                                                                                                                                                                          
            </Column>                                                                                                                                                                                                                                          
            <Column>                                                                                                                                                                                                                                           
                <Text text="{i18n>userDisplayName}" />                                                                                                                                                                                                         
            </Column>                                                                                                                                                                                                                                          
            <Column>                                                                                                                                                                                                                                           
                <Text text="{i18n>userDepartment}" />                                                                                                                                                                                                          
            </Column>                                                                                                                                                                                                                                          
            <Column>                                                                                                                                                                                                                                           
                <Text text="{i18n>userEmail}" />                                                                                                                                                                                                               
            </Column>                                                                                                                                                                                                                                          
            <Column>                                                                                                                                                                                                                                           
                <Text text="Total Active Work Items" />                                                                                                                                                                                                        
            </Column>                                                                                                                                                                                                                                          
        </columns>                                                                                                                                                                                                                                             
        <ColumnListItem type="Navigation">                                                                                                                                                                                                                     
            <cells>                                                                                                                                                                                                                                            
                <Text text="{adminInboxViewModel>UserID}" />                                                                                                                                                                                                   
                <Text text="{adminInboxViewModel>PersonFullName}" />                                                                                                                                                                                           
                <Text text="{adminInboxViewModel>Department}" />                                                                                                                                                                                               
                <Text text="{adminInboxViewModel>Email}" />                                                                                                                                                                                                    
                <Text text="{adminInboxViewModel>TotalActiveWorkItems}" />                                                                                                                                                                                     
            </cells>                                                                                                                                                                                                                                           
        </ColumnListItem>                                                                                                                                                                                                                                      
    </Table>                                                                                                                                                                                                                                                   
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               