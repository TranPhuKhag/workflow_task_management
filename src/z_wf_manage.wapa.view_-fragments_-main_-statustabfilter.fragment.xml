<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <IconTabFilter                                                                                                                                                                                                                                             
        key="all"                                                                                                                                                                                                                                              
        showAll="true"                                                                                                                                                                                                                                         
        count="{/WfTasks/$count}"                                                                                                                                                                                                                              
        text="{i18n>WorklistFilterTasksAll}"                                                                                                                                                                                                                   
    />                                                                                                                                                                                                                                                         
    <IconTabSeparator />                                                                                                                                                                                                                                       
    <IconTabFilter                                                                                                                                                                                                                                             
        key="ready"                                                                                                                                                                                                                                            
        icon="sap-icon://task"                                                                                                                                                                                                                                 
        iconColor="Default"                                                                                                                                                                                                                                    
        text="{i18n>WorklistFilterTasksReady}"                                                                                                                                                                                                                 
        count="{statusFilterCounter>/readyCount}"                                                                                                                                                                                                              
    />                                                                                                                                                                                                                                                         
    <IconTabFilter                                                                                                                                                                                                                                             
        key="selected"                                                                                                                                                                                                                                         
        icon="sap-icon://employee-approvals"                                                                                                                                                                                                                   
        iconColor="Neutral"                                                                                                                                                                                                                                    
        text="{i18n>WorklistFilterTasksSelected}"                                                                                                                                                                                                              
        count="{statusFilterCounter>/selectedCount}"                                                                                                                                                                                                           
    />                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    <IconTabFilter                                                                                                                                                                                                                                             
        key="waiting"                                                                                                                                                                                                                                          
        icon="sap-icon://pending"                                                                                                                                                                                                                              
        iconColor="Critical"                                                                                                                                                                                                                                   
        text="{i18n>WorklistFilterTasksWaiting}"                                                                                                                                                                                                               
        count="{statusFilterCounter>/waitingCount}"                                                                                                                                                                                                            
    />                                                                                                                                                                                                                                                         
    <IconTabSeparator />                                                                                                                                                                                                                                       
    <IconTabFilter                                                                                                                                                                                                                                             
        key="ondue"                                                                                                                                                                                                                                            
        icon="sap-icon://away"                                                                                                                                                                                                                                 
        iconColor="{                                                                                                                                                                                                                                           
            path: 'statusFilterCounter>/isHasDueOn',                                                                                                                                                                                                           
            formatter: '.formatter.formatOnDueIconColor'                                                                                                                                                                                                       
        }"                                                                                                                                                                                                                                                     
        text="{                                                                                                                                                                                                                                                
            parts:[                                                                                                                                                                                                                                            
                {path: 'i18n>WorklistFilterTasksOnDue'},                                                                                                                                                                                                       
                {path: 'statusFilterCounter>/isHasDueOn'}                                                                                                                                                                                                      
            ],                                                                                                                                                                                                                                                 
            formatter: '.formatter.formatStatusTabIndicator'                                                                                                                                                                                                   
        }"                                                                                                                                                                                                                                                     
    />                                                                                                                                                                                                                                                         
    <IconTabFilter                                                                                                                                                                                                                                             
        key="overdue"                                                                                                                                                                                                                                          
        icon="sap-icon://lateness"                                                                                                                                                                                                                             
        iconColor="{                                                                                                                                                                                                                                           
            path: 'statusFilterCounter>/isHasOverdue',                                                                                                                                                                                                         
            formatter: '.formatter.formatOverdueIconColor'                                                                                                                                                                                                     
        }"                                                                                                                                                                                                                                                     
        text="{                                                                                                                                                                                                                                                
            parts:[                                                                                                                                                                                                                                            
                {path: 'i18n>WorklistFilterTasksOverdue'},                                                                                                                                                                                                     
                {path: 'statusFilterCounter>/isHasOverdue'}                                                                                                                                                                                                    
            ],                                                                                                                                                                                                                                                 
            formatter: '.formatter.formatStatusTabIndicator'                                                                                                                                                                                                   
        }"                                                                                                                                                                                                                                                     
    />                                                                                                                                                                                                                                                         
    <IconTabSeparator />                                                                                                                                                                                                                                       
    <IconTabFilter                                                                                                                                                                                                                                             
        key="more"                                                                                                                                                                                                                                             
        icon="sap-icon://overflow"                                                                                                                                                                                                                             
        text="{i18n>WorklistFilterTasksMore}"                                                                                                                                                                                                                  
    >                                                                                                                                                                                                                                                          
        <items>                                                                                                                                                                                                                                                
            <IconTabFilter                                                                                                                                                                                                                                     
                key="started"                                                                                                                                                                                                                                  
                icon="sap-icon://begin"                                                                                                                                                                                                                        
                iconColor="Critical"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksStarted}"                                                                                                                                                                                                       
                count="{statusFilterCounter>/startedCount}"                                                                                                                                                                                                    
            />                                                                                                                                                                                                                                                 
            <IconTabFilter                                                                                                                                                                                                                                     
                key="committed"                                                                                                                                                                                                                                
                icon="sap-icon://org-chart"                                                                                                                                                                                                                    
                iconColor="Critical"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksCommitted}"                                                                                                                                                                                                     
                count="{statusFilterCounter>/committedCount}"                                                                                                                                                                                                  
            />                                                                                                                                                                                                                                                 
            <IconTabSeparator />                                                                                                                                                                                                                               
            <IconTabFilter                                                                                                                                                                                                                                     
                key="checked"                                                                                                                                                                                                                                  
                icon="sap-icon://inspection"                                                                                                                                                                                                                   
                iconColor="Positive"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksChecked}"                                                                                                                                                                                                       
                count="{statusFilterCounter>/checkedCount}"                                                                                                                                                                                                    
            />                                                                                                                                                                                                                                                 
            <IconTabFilter                                                                                                                                                                                                                                     
                key="completed"                                                                                                                                                                                                                                
                icon="sap-icon://complete"                                                                                                                                                                                                                     
                iconColor="Positive"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksCompleted}"                                                                                                                                                                                                     
                count="{statusFilterCounter>/completedCount}"                                                                                                                                                                                                  
            />                                                                                                                                                                                                                                                 
            <IconTabSeparator />                                                                                                                                                                                                                               
            <IconTabFilter                                                                                                                                                                                                                                     
                key="cancelled"                                                                                                                                                                                                                                
                icon="sap-icon://decline"                                                                                                                                                                                                                      
                iconColor="Negative"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksCancelled}"                                                                                                                                                                                                     
                count="{statusFilterCounter>/cancelledCount}"                                                                                                                                                                                                  
            />                                                                                                                                                                                                                                                 
            <IconTabFilter                                                                                                                                                                                                                                     
                key="error"                                                                                                                                                                                                                                    
                icon="sap-icon://error"                                                                                                                                                                                                                        
                iconColor="Negative"                                                                                                                                                                                                                           
                text="{i18n>WorklistFilterTasksError}"                                                                                                                                                                                                         
                count="{statusFilterCounter>/errorCount}"                                                                                                                                                                                                      
            />                                                                                                                                                                                                                                                 
        </items>                                                                                                                                                                                                                                               
    </IconTabFilter>                                                                                                                                                                                                                                           
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               