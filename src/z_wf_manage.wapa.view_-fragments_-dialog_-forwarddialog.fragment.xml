<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <Dialog                                                                                                                                                                                                                                                    
        title="{i18n>forwardDialogTitle}"                                                                                                                                                                                                                      
        id="forwardDialog"                                                                                                                                                                                                                                     
        contentWidth="400px"                                                                                                                                                                                                                                   
        contentHeight="auto"                                                                                                                                                                                                                                   
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                <Label                                                                                                                                                                                                                                         
                    text="{i18n>forwardUserLabel}"                                                                                                                                                                                                             
                    labelFor="forwardUserInput"                                                                                                                                                                                                                
                    required="true"                                                                                                                                                                                                                            
                />                                                                                                                                                                                                                                             
                <Input                                                                                                                                                                                                                                         
                    id="forwardUserInput"                                                                                                                                                                                                                      
                    placeholder="{i18n>forwardUserPlaceholder}"                                                                                                                                                                                                
                    showValueHelp="true"                                                                                                                                                                                                                       
                    required="true"                                                                                                                                                                                                                            
                    valueHelpRequest=".onOpenUserSearchHelp"                                                                                                                                                                                                   
                />                                                                                                                                                                                                                                             
                <Label                                                                                                                                                                                                                                         
                    labelFor="forwardReasonInput"                                                                                                                                                                                                              
                    text="{i18n>forwardReasonLabel}"                                                                                                                                                                                                           
                />                                                                                                                                                                                                                                             
                <TextArea                                                                                                                                                                                                                                      
                    id="forwardReasonInput"                                                                                                                                                                                                                    
                    width="100%"                                                                                                                                                                                                                               
                    placeholder="{i18n>forwardReasonPlaceholder}"                                                                                                                                                                                              
                    growing="true"                                                                                                                                                                                                                             
                />                                                                                                                                                                                                                                             
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
        <buttons>                                                                                                                                                                                                                                              
            <Button                                                                                                                                                                                                                                            
                type="Emphasized"                                                                                                                                                                                                                              
                text="{i18n>buttonForward}"                                                                                                                                                                                                                    
                press=".onConfirmForward"                                                                                                                                                                                                                      
            />                                                                                                                                                                                                                                                 
            <Button                                                                                                                                                                                                                                            
                text="{i18n>btnCancel}"                                                                                                                                                                                                                        
                press=".onCancelForward"                                                                                                                                                                                                                       
            />                                                                                                                                                                                                                                                 
        </buttons>                                                                                                                                                                                                                                             
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               