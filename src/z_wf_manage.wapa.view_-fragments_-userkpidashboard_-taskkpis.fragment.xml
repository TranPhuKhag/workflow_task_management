<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
>                                                                                                                                                                                                                                                              
    <Panel                                                                                                                                                                                                                                                     
        class="sapUiSmallMargin"                                                                                                                                                                                                                               
        headerText="{i18n>myKPIHeader}"                                                                                                                                                                                                                        
        width="98.5%"                                                                                                                                                                                                                                          
    >                                                                                                                                                                                                                                                          
        <HBox                                                                                                                                                                                                                                                  
            wrap="Wrap"                                                                                                                                                                                                                                        
            width="100%"                                                                                                                                                                                                                                       
            justifyContent="SpaceBetween"                                                                                                                                                                                                                      
            class="statsCardsRow"                                                                                                                                                                                                                              
        >                                                                                                                                                                                                                                                      
            <!-- My Open Tasks -->                                                                                                                                                                                                                             
            <GenericTile                                                                                                                                                                                                                                       
                header="{i18n>myKPIOpenTasks}"                                                                                                                                                                                                                 
                frameType="OneByOne"                                                                                                                                                                                                                           
                state="{= ${kpiModel>/busy} ? 'Loading' : 'Loaded'}"                                                                                                                                                                                           
                width="100%"                                                                                                                                                                                                                                   
            >                                                                                                                                                                                                                                                  
                <layoutData>                                                                                                                                                                                                                                   
                    <FlexItemData                                                                                                                                                                                                                              
                        growFactor="1"                                                                                                                                                                                                                         
                        shrinkFactor="1"                                                                                                                                                                                                                       
                        minWidth="14rem"                                                                                                                                                                                                                       
                    />                                                                                                                                                                                                                                         
                </layoutData>                                                                                                                                                                                                                                  
                <tileContent>                                                                                                                                                                                                                                  
                    <TileContent unit="{i18n>tasksUnit}">                                                                                                                                                                                                      
                        <content>                                                                                                                                                                                                                              
                            <NumericContent                                                                                                                                                                                                                    
                                value="{kpiModel>/MyOpenTasksCount}"                                                                                                                                                                                           
                                icon="sap-icon://task"                                                                                                                                                                                                         
                                valueColor="Good"                                                                                                                                                                                                              
                                indicator="None"                                                                                                                                                                                                               
                                withMargin="false"                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                        </content>                                                                                                                                                                                                                             
                    </TileContent>                                                                                                                                                                                                                             
                </tileContent>                                                                                                                                                                                                                                 
            </GenericTile>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            <!-- Due Today -->                                                                                                                                                                                                                                 
            <GenericTile                                                                                                                                                                                                                                       
                header="{i18n>myKPIDueTodayTasks}"                                                                                                                                                                                                             
                frameType="OneByOne"                                                                                                                                                                                                                           
                state="{= ${kpiModel>/busy} ? 'Loading' : 'Loaded'}"                                                                                                                                                                                           
                width="100%"                                                                                                                                                                                                                                   
            >                                                                                                                                                                                                                                                  
                <layoutData>                                                                                                                                                                                                                                   
                    <FlexItemData                                                                                                                                                                                                                              
                        growFactor="1"                                                                                                                                                                                                                         
                        shrinkFactor="1"                                                                                                                                                                                                                       
                        minWidth="14rem"                                                                                                                                                                                                                       
                    />                                                                                                                                                                                                                                         
                </layoutData>                                                                                                                                                                                                                                  
                <tileContent>                                                                                                                                                                                                                                  
                    <TileContent unit="{i18n>tasksUnit}">                                                                                                                                                                                                      
                        <content>                                                                                                                                                                                                                              
                            <NumericContent                                                                                                                                                                                                                    
                                value="{kpiModel>/DueTodayCount}"                                                                                                                                                                                              
                                icon="sap-icon://appointment"                                                                                                                                                                                                  
                                valueColor="Critical"                                                                                                                                                                                                          
                                indicator="None"                                                                                                                                                                                                               
                                withMargin="false"                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                        </content>                                                                                                                                                                                                                             
                    </TileContent>                                                                                                                                                                                                                             
                </tileContent>                                                                                                                                                                                                                                 
            </GenericTile>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            <!-- Overdue Tasks -->                                                                                                                                                                                                                             
            <GenericTile                                                                                                                                                                                                                                       
                header="{i18n>OverdueTasksText}"                                                                                                                                                                                                               
                frameType="OneByOne"                                                                                                                                                                                                                           
                state="{= ${kpiModel>/busy} ? 'Loading' : 'Loaded'}"                                                                                                                                                                                           
                width="100%"                                                                                                                                                                                                                                   
            >                                                                                                                                                                                                                                                  
                <layoutData>                                                                                                                                                                                                                                   
                    <FlexItemData                                                                                                                                                                                                                              
                        growFactor="1"                                                                                                                                                                                                                         
                        shrinkFactor="1"                                                                                                                                                                                                                       
                        minWidth="14rem"                                                                                                                                                                                                                       
                    />                                                                                                                                                                                                                                         
                </layoutData>                                                                                                                                                                                                                                  
                <tileContent>                                                                                                                                                                                                                                  
                    <TileContent unit="{i18n>tasksUnit}">                                                                                                                                                                                                      
                        <content>                                                                                                                                                                                                                              
                            <NumericContent                                                                                                                                                                                                                    
                                value="{kpiModel>/MyOverdueCount}"                                                                                                                                                                                             
                                icon="sap-icon://alert"                                                                                                                                                                                                        
                                valueColor="Error"                                                                                                                                                                                                             
                                indicator="Down"                                                                                                                                                                                                               
                                withMargin="false"                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                        </content>                                                                                                                                                                                                                             
                    </TileContent>                                                                                                                                                                                                                             
                </tileContent>                                                                                                                                                                                                                                 
            </GenericTile>                                                                                                                                                                                                                                     
        </HBox>                                                                                                                                                                                                                                                
    </Panel>                                                                                                                                                                                                                                                   
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               